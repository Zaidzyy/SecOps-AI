# SecOps-AI environment. Copy to `.env` -- both docker compose and the
# bare-metal app (python-dotenv) read it. `.env` is gitignored; keep it that way.

# Session-cookie signing key. REQUIRED to run bare-metal; in docker compose an
# unset key falls back to a publicly-known DEMO value (fine for a local demo,
# never for anything reachable by others). Generate a real one:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECOPS_SECRET_KEY=

# Groq cloud triage (console chat + background advisories). Optional --
# without it the chat degrades to an error message. Get a key at console.groq.com.
GROQ_API_KEY=

# --- Optional overrides (defaults shown) ------------------------------------
#SECOPS_SEED_DEMO=1                 # compose: replay demo pcap on first boot
#SECOPS_HOST=127.0.0.1              # bare-metal bind (container uses 0.0.0.0)
#SECOPS_PORT=5000
#SECOPS_ALLOWED_ORIGINS=            # comma-separated Socket.IO origins
#SECOPS_DEBUG=0
#SECOPS_COOKIE_SECURE=0             # set 1 behind HTTPS
#SECOPS_OLLAMA_MODEL=llama3.2       # edge-alerts model (must be pulled in Ollama)
